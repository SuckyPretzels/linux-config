;;; Code:

(require 'base16-theme)

(defvar my-tokyo-night-moon-colors
  '(:base00 "#000000"
    :base01 "#1e2030"
    :base02 "#2d3f76"
    :base03 "#3b4261"
    :base04 "#636da6"
    :base05 "#828bb8"
    :base06 "#aeb4d1"
    :base07 "#c8d3f5"
    :base08 "#ff757f"
    :base09 "#ffc777"
    :base0A "#ffdf77"
    :base0B "#c3e88d"
    :base0C "#86e1fc"
    :base0D "#82aaff"
    :base0E "#fca7ea"
    :base0F "#c53b53")
  "My adjusted colors for tokyo-night-moon.")

;; Define the theme
(deftheme my-tokyo-night-moon)

;; Add all the faces to the theme
(base16-theme-define my-tokyo-night-moon tokyo-night-moon-colors)

;; Mark the theme as provided
(provide-theme 'my-tokyo-night-moon)

(provide 'my-tokyo-night-moon-theme)

;;; my-tokyo-night-moon.el ends here
